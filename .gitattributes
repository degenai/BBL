# Normalize all text files to LF in the repo and on checkout.
# Silences the core.autocrlf=true "LF will be replaced by CRLF" warnings on Windows.
* text=auto eol=lf

# Binary assets — never apply line-ending conversion.
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.gif  binary
*.pdf  binary
*.ico  binary
